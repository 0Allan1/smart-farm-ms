# Copy this file to .env and fill in your own values
# cp .env.example .env

# ─── Database ───────────────────────────────────────────────────────────────
# Replace with your own PostgreSQL username, password, and database name
DATABASE_URL="postgresql://YOUR_POSTGRES_USER:YOUR_POSTGRES_PASSWORD@localhost:5432/sfms_db"

# ─── Authentication ──────────────────────────────────────────────────────────
# Any long random string (minimum 32 characters). Keep this secret!
JWT_SECRET="replace-this-with-a-long-random-secret-key"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
